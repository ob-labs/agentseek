---
hide_sidebar: true
---

# {{ ui.title }}

{{ ui.summary }}

<div class="hub-page">
  <div class="hub-intro terminal-card">
    <p class="landing-kicker">{{ ui.intro_kicker }}</p>
    <p>{{ ui.intro_body | safe }}</p>
  </div>

  <div class="hub-controls">
    <div class="hub-search-wrap">
      <input
        class="hub-search"
        type="text"
        placeholder="{{ ui.search_placeholder }}"
        autocomplete="off"
        data-hub-search
      />
    </div>
    <div class="hub-tabs">
      <button class="hub-tab active" type="button" data-hub-tab="all">{{ ui.all_label }}</button>
{% for category in categories %}
      <button class="hub-tab" type="button" data-hub-tab="{{ category.name }}">{{ ui.category_labels.get(category.name, category.name) }}</button>
{% endfor %}
    </div>
    <p class="hub-results">
      {{ ui.showing_label }} <span data-hub-shown>0</span> {{ ui.of_label }} <span data-hub-total>0</span> {{ ui.items_label }}
    </p>
  </div>

{% for category in categories %}
  <section class="hub-section" data-hub-category="{{ category.name }}">
    <h2>{{ ui.category_labels.get(category.name, category.name) }}</h2>
    <div class="hub-grid">
{% for item in category["items"] %}
{% include "partials/hub_card.md.j2" %}
{% endfor %}
    </div>
  </section>
{% endfor %}

  <div class="hub-empty" hidden data-hub-empty>
    {{ ui.empty_label }}
  </div>
</div>
