# CopilotKit runtime (this app) — default 4001 so it does not clash with examples/ag-ui (4000).
COPILOTKIT_PORT=4001

# Gateway AG-UI agent URL (HttpAgent target).
AGENTSEEK_AG_UI_AGENT_URL=http://127.0.0.1:8088/agent

# Vite dev proxy: Copilot runtime (must match COPILOTKIT_PORT).
VITE_COPILOTKIT_RUNTIME_PROXY=http://127.0.0.1:4001

# Vite dev proxy: raw gateway (optional; used for /agent passthrough if needed).
VITE_AGENTSEEK_AG_UI_URL=http://127.0.0.1:8088

# Browser → Vite → runtime (usually leave default).
# VITE_COPILOTKIT_RUNTIME_URL=/api/copilotkit
