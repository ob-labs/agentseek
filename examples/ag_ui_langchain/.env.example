# ---------------------------------------------------------------------------
# LangChain + AG-UI example — merge into repository root `.env` or export.
# Gateway is started from the repo root (`uv run agentseek gateway`), so the
# usual agentseek `.env` is already loaded. Add / copy the block below there, or
# `source` a file that exports the same names.
# ---------------------------------------------------------------------------

# From root `.env`, copy the same three lines (model id, API key, API base), e.g.:
# AGENTSEEK_MODEL=openai:your-model
# AGENTSEEK_API_KEY=sk-...
# AGENTSEEK_API_BASE=https://...
#
# For `openai:*` models, `ag_ui_langchain.settings.AgUiLangchainDemoSettings.apply_openai_env_bridge()`
# copies these into `OPENAI_API_KEY` / `OPENAI_API_BASE` when those are unset (pydantic-backed),
# so LangChain does not require a second set of variables.
#
# Do not commit real keys into this file; paste your values into repository root `.env`
# and/or `examples/ag_ui_langchain/.env`.

# ---------------------------------------------------------------------------
# Required for this example only (not in default root `.env`)
# ---------------------------------------------------------------------------

# So Python can import `ag_ui_langchain.demo_binding` when the gateway starts.
# When you run `uv run --env-file .env --env-file examples/ag_ui_langchain/.env ...`
# from the repository root, setting `PYTHONPATH=examples` here is sufficient.
# Export it manually only if you start the gateway some other way.
PYTHONPATH=examples

AGENTSEEK_LANGCHAIN_SPEC=ag_ui_langchain.demo_binding:build_spec

# Recommended: token streaming to the CopilotKit UI over AG-UI.
AGENTSEEK_STREAM_OUTPUT=true
