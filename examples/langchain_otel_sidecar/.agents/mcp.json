{
  "mcpServers": {
    "otel": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "--from",
        "opentelemetry-mcp",
        "opentelemetry-mcp"
      ],
      "env": {
        "BACKEND_TYPE": "jaeger",
        "BACKEND_URL": "http://jaeger:16686"
      }
    }
  }
}
