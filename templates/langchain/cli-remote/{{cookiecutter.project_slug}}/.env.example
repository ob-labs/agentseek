# AgentSeek reads this file for lifecycle checks and Bub-compatible runtime aliases.
AGENTSEEK_MODEL={{ cookiecutter.default_model }}
AGENTSEEK_API_KEY=
AGENTSEEK_API_BASE=
AGENTSEEK_LANGCHAIN_SPEC={{ cookiecutter.project_slug }}.gateway_binding:build_spec

# The bridge calls this LangGraph Agent Server.
LANGGRAPH_URL={{ cookiecutter.langgraph_url }}
LANGGRAPH_ASSISTANT_ID={{ cookiecutter.assistant_id }}
LANGGRAPH_THREAD_ON_SESSION=false

# When AGENTSEEK_MODEL starts with "openai:", the project maps AGENTSEEK_API_KEY
# and AGENTSEEK_API_BASE to OpenAI-compatible environment variables if they are unset.
