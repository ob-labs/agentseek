# ─── OpenVINO Model Paths ─────────────────────────────────────────────────────
# Point these at your local OpenVINO IR model directories.
# Run `uv run convert-models` to download and convert default models.
LLM_MODEL_PATH={{ cookiecutter.llm_model_path }}
EMBEDDING_MODEL_PATH={{ cookiecutter.embedding_model_path }}

# Device for inference: CPU, GPU, or NPU
OPENVINO_DEVICE={{ cookiecutter.device }}

# Max tokens for LLM generation
MAX_NEW_TOKENS=512

# ─── SeekDB (vector store) ───────────────────────────────────────────────────
# Start SeekDB with `docker compose up -d` or pylibseekdb embedded service.
SEEKDB_HOST=127.0.0.1
SEEKDB_PORT=2881
SEEKDB_USER=root@test
SEEKDB_PASSWORD=
SEEKDB_DB_NAME={{ cookiecutter.seekdb_db_name }}
VECTOR_TABLE_NAME={{ cookiecutter.vector_table_name }}

# ─── LangSmith (optional) ────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT={{ cookiecutter.project_slug }}
