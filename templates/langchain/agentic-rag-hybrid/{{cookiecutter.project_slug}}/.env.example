# --- Model + provider connection ------------------------------------------
# Choose one provider, then fill only that provider's block below.
# AgentSeek lifecycle checks AGENTSEEK_MODEL_PROVIDER and AGENTSEEK_MODEL.
AGENTSEEK_MODEL_PROVIDER={{ cookiecutter.default_model_provider }}
# The generated agent defaults to the scaffold-time model, but you can
# override it here without editing code.
AGENTSEEK_MODEL={{ cookiecutter.default_model }}
# If you switch providers, switch this model too. Examples:
# - openai: gpt-4.1-mini
# - anthropic: claude-3-5-sonnet-latest
# - google_genai: gemini-2.5-pro
# Compatibility alias for AGENTSEEK_MODEL also works: BUB_MODEL.

# OpenAI / OpenAI-compatible
# Required only when AGENTSEEK_MODEL_PROVIDER=openai.
# Leave OPENAI_API_BASE empty to use the official OpenAI endpoint.
OPENAI_API_KEY=
OPENAI_API_BASE=

# Anthropic / Anthropic-compatible
# Required only when AGENTSEEK_MODEL_PROVIDER=anthropic.
# Leave ANTHROPIC_API_URL empty to use the official Anthropic endpoint.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=

# Gemini / Google-compatible
# Required only when AGENTSEEK_MODEL_PROVIDER=google_genai.
# Leave GOOGLE_API_BASE empty to use the official Gemini Developer API endpoint.
GOOGLE_API_KEY=
GOOGLE_API_BASE=

# Some OpenAI-compatible gateways emit large tool-call chunks with long gaps.
# Only used when AGENTSEEK_MODEL_PROVIDER=openai. Set to 0 to disable.
LANGCHAIN_OPENAI_STREAM_CHUNK_TIMEOUT_S=300

# --- SeekDB ----------------------------------------------------------------
# Start SeekDB: docker compose up -d
# AgentSeek lifecycle checks these connection variables and uses defaults
# from .agentseek/lifecycle.toml when they are absent from .env.
SEEKDB_HOST=127.0.0.1
SEEKDB_PORT=2881
SEEKDB_USER=root
SEEKDB_PASSWORD=
SEEKDB_DB_NAME={{ cookiecutter.seekdb_db_name }}
IMAGE_TABLE_NAME={{ cookiecutter.image_table_name }}

# --- Image embedding + captioning -----------------------------------------
EMBEDDING_TYPE=dashscope
EMBEDDING_API_KEY=
EMBEDDING_MODEL={{ cookiecutter.embedding_model }}
EMBEDDING_DIMENSION={{ cookiecutter.embedding_dimension }}
VLM_API_KEY=
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL={{ cookiecutter.vlm_model }}

# --- Hybrid behavior --------------------------------------------------------
HYBRID_DEFAULT_MODE=balanced
HYBRID_RECALL_MULTIPLIER=5
HYBRID_MAX_TOP_K=20

# --- Local services ---------------------------------------------------------
MEDIA_DATA_DIR=./data
MEDIA_MAX_UPLOAD_MB=50
VITE_LANGGRAPH_API_URL=http://127.0.0.1:2024
VITE_CUSTOM_ROUTES_URL=http://127.0.0.1:2024

# --- LangSmith (optional tracing) -----------------------------------------
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
# LANGSMITH_PROJECT={{ cookiecutter.project_slug }}
