# Copy this file to `.env`. AgentSeek lifecycle commands read only the
# variables declared in `.agentseek/lifecycle.toml` for readiness checks.
# Runtime processes started by `agentseek dev` load this file explicitly.

# Model provider. `AGENTSEEK_MODEL` accepts LangChain model identifiers such as
# `openai:gpt-4o-mini` or an OpenAI-compatible provider-specific model id.
AGENTSEEK_MODEL={{ cookiecutter.default_model }}

# Required for `agentseek doctor` unless an alias such as OPENAI_API_KEY is set
# in the shell environment.
AGENTSEEK_API_KEY=

# Optional OpenAI-compatible API base URL. Leave empty for provider defaults.
AGENTSEEK_API_BASE=

# Gateway and local frontend ports.
AGENTSEEK_STREAM_OUTPUT=true
AGENTSEEK_AG_UI_PORT={{ cookiecutter.gateway_port }}
FRONTEND_PORT={{ cookiecutter.frontend_port }}
COPILOTKIT_PORT={{ cookiecutter.copilotkit_port }}
AGENTSEEK_AG_UI_AGENT_URL=http://127.0.0.1:{{ cookiecutter.gateway_port }}/agent

# Optional compose profiles: otel, feishu, or otel,feishu.
# COMPOSE_PROFILES=otel

# Optional Feishu channel.
AGENTSEEK_FEISHU_APP_ID=
AGENTSEEK_FEISHU_APP_SECRET=
AGENTSEEK_FEISHU_VERIFICATION_TOKEN=
# AGENTSEEK_FEISHU_ENCRYPT_KEY=

# --- LangSmith, optional tracing ------------------------------------------
# Enable LangSmith tracing to inspect agent runs, token usage, and latency.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
# Optional: customize the project name shown in LangSmith UI (defaults to "default").
# LANGSMITH_PROJECT=my-custom-project

# --- OpenTelemetry / Phoenix, optional tracing ----------------------------
# Enable with COMPOSE_PROFILES=otel for compose runs.
AGENTSEEK_OTEL_ENABLED=false
AGENTSEEK_OTEL_SERVICE_NAME={{ cookiecutter.project_slug }}
AGENTSEEK_OTEL_PROJECT_NAME={{ cookiecutter.project_slug }}
AGENTSEEK_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:6006/v1/traces
