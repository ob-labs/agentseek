# bubseek environment example
# Copy to `.env` and fill values. bubseek forwards these to the Bub subprocess.

# ---------------------------------------------------------------------------
# OpenAI Codex OAuth setup
# ---------------------------------------------------------------------------
# BUB_MODEL=openai:gpt-5.4
# Uses existing Codex OAuth credentials under CODEX_HOME (default ~/.codex).
# If your auth is stored elsewhere:
# CODEX_HOME=/path/to/.codex

# ---------------------------------------------------------------------------
# Agent runtime (optional)
# ---------------------------------------------------------------------------
# BUB_MAX_STEPS=50
# BUB_MAX_TOKENS=1024
# BUB_MODEL_TIMEOUT_SECONDS=300
# BUB_HOME=~/.bub

# ---------------------------------------------------------------------------
# Telegram channel (optional)
# ---------------------------------------------------------------------------
# BUB_TELEGRAM_TOKEN=123456:telegram-bot-token
# BUB_TELEGRAM_ALLOW_USERS=123456789,my_username
# BUB_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890
# BUB_TELEGRAM_PROXY=http://127.0.0.1:1080

# ---------------------------------------------------------------------------
# Web search tool (optional, bundled)
# ---------------------------------------------------------------------------
# BUB_SEARCH_OLLAMA_API_KEY=your-ollama-api-key
# BUB_SEARCH_OLLAMA_API_BASE=https://ollama.com/api

# ---------------------------------------------------------------------------
# Feishu channel (optional, bundled)
# ---------------------------------------------------------------------------
# BUB_FEISHU_APP_ID=your-app-id
# BUB_FEISHU_APP_SECRET=your-app-secret
# BUB_FEISHU_VERIFICATION_TOKEN=
# BUB_FEISHU_ENCRYPT_KEY=
# BUB_FEISHU_ALLOW_USERS=
# BUB_FEISHU_ALLOW_CHATS=

# ---------------------------------------------------------------------------
# DingTalk channel (optional, bundled)
# ---------------------------------------------------------------------------
# BUB_DINGTALK_CLIENT_ID=your-appkey
# BUB_DINGTALK_CLIENT_SECRET=your-appsecret
# BUB_DINGTALK_ALLOW_USERS=*

# ---------------------------------------------------------------------------
# Tape store SQLAlchemy (optional, bundled)
# ---------------------------------------------------------------------------
# Default SQLite (~/.bub/tapes.db when URL is unset)
# BUB_TAPESTORE_SQLALCHEMY_URL=sqlite+pysqlite:///path/to/tapes.db
# BUB_TAPESTORE_SQLALCHEMY_ECHO=false

# OceanBase/SeekDB mode
# Local: BUB_TAPESTORE_SQLALCHEMY_URL=mysql+pymysql://root:@127.0.0.1:2881/bub
# docker-compose builds URL from OCEANBASE_* vars
# OCEANBASE_HOST=127.0.0.1
# OCEANBASE_PORT=2881
# OCEANBASE_USER=root
# OCEANBASE_PASSWORD=
# OCEANBASE_DATABASE=bub
# OCEANBASE_ROOT_PASSWORD=

# Proxy
# HTTP_PROXY=http://127.0.0.1:13659
# HTTPS_PROXY=http://127.0.0.1:13659

# Local Python bootstrap and disable TLS verification
# PYTHONPATH=.:scripts
# BUBSEEK_DISABLE_TLS_VERIFY=1
